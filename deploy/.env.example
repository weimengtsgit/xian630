# ---- Claude Code gateway (drives real generation) ----
# The in-container `claude` CLI talks to whatever Anthropic-compatible gateway
# these three vars point at. SWAPPABLE: to switch to 火山 agent plan, 智谱, or
# direct Anthropic, edit these three lines + `podman compose up -d
# --force-recreate factory`. Leave FACTORY_FAKE_CLAUDE=1 (below) to skip the CLI
# entirely (deterministic fake generation, no gateway needed).
#
# Volcengine Ark "coding plan":
ANTHROPIC_BASE_URL=https://ark.cn-beijing.volces.com/api/coding
ANTHROPIC_AUTH_TOKEN=ark-REPLACE-ME
ANTHROPIC_MODEL=ark-code-latest
# Direct Anthropic (alternative): set ANTHROPIC_BASE_URL=https://api.anthropic.com,
# ANTHROPIC_API_KEY=sk-ant-..., and leave AUTH_TOKEN empty.

# ---- Host container runtime ----
# Which CLI factory shells out to. Must match the host runtime. podman | docker
FACTORY_CONTAINER_RUNTIME=podman
# Host runtime socket, mounted into the factory container.
#   Podman host (rootful socket): /run/podman/podman.sock
#   Docker host:                   /var/run/docker.sock
CONTAINER_SOCK=/run/podman/podman.sock

# ---- Optional ----
# 1 = deterministic fake claude runner (no API key needed; no real generation).
FACTORY_FAKE_CLAUDE=
# Host port the portal (embedded page) is served on.
PORTAL_PORT=80
# Host the factory probes host-published apps on FROM INSIDE its container.
# Keep "host-gateway" for containerized deploys (resolves to the host bridge IP).
FACTORY_HEALTH_HOST=host-gateway
# Host used in the user-facing deployment URL for generated apps. Set to the IP
# users browse with (e.g. 220.154.5.91 public or 192.168.0.20 internal). Defaults
# to host-gateway; override when generated-app links must be externally reachable.
FACTORY_APP_URL_HOST=host-gateway
