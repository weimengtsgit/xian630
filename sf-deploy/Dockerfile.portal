# syntax=docker/dockerfile:1
# Portal front end: serve pre-built Vite dist with nginx, reverse-proxy /api to factory.
# Pre-built dist is copied from artifacts/dist/ (built locally before deploy).
FROM docker.m.daocloud.io/library/nginx:1.27-alpine
COPY nginx/portal.conf /etc/nginx/conf.d/default.conf
COPY nginx/entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh
COPY artifacts/dist /usr/share/nginx/html
EXPOSE 80
ENTRYPOINT ["/entrypoint.sh"]
