# syntax=docker/dockerfile:1
# factory-server: pre-built binary + node20 runtime carrying the claude CLI, git,
# and BOTH podman + docker CLIs so the SAME image runs under a Podman or Docker host.
# Pre-built artifacts are copied from artifacts/ (built locally before deploy).

# docker CLI (for Docker-host deployments) — pulled via mirror.
FROM docker.m.daocloud.io/library/docker:cli AS dockercli

FROM docker.m.daocloud.io/library/node:20-bookworm
# China-friendly Debian mirror for apt (podman install).
RUN set -eux; \
    if [ -f /etc/apt/sources.list.d/debian.sources ]; then \
      sed -i 's|deb.debian.org|mirrors.tuna.tsinghua.edu.cn|g; s|security.debian.org|mirrors.tuna.tsinghua.edu.cn|g' /etc/apt/sources.list.d/debian.sources; \
    elif [ -f /etc/apt/sources.list ]; then \
      sed -i 's|deb.debian.org|mirrors.tuna.tsinghua.edu.cn|g; s|security.debian.org|mirrors.tuna.tsinghua.edu.cn|g' /etc/apt/sources.list; \
    fi
RUN apt-get update && apt-get install -y --no-install-recommends podman ca-certificates git \
    && rm -rf /var/lib/apt/lists/*
COPY --from=dockercli /usr/local/bin/docker /usr/local/bin/docker
# Claude Code CLI (npmmirror is faster/reliable from the CN host).
RUN npm config set registry https://registry.npmmirror.com \
    && npm install -g @anthropic-ai/claude-code

WORKDIR /workspace
COPY artifacts/factory-server /usr/local/bin/factory-server
RUN chmod +x /usr/local/bin/factory-server
# Reference-only skill tree + scene blueprints the generator/clarifier reads.
COPY skills /workspace/.claude/skills
COPY scene /workspace/scene
# Scene catalog (preset-app visibility) the scanner loads at startup.
COPY factory-catalog /workspace/.factory

ENV FACTORY_ADDR=0.0.0.0:8787 \
    FACTORY_WORKSPACE_ROOT=/workspace \
    FACTORY_DBPATH=/data/state.db \
    FACTORY_ARTIFACT_ROOT=/data/runs \
    FACTORY_LOG_PATH=/data/runs/factory-server.jsonl \
    HOME=/root
EXPOSE 8787
ENTRYPOINT ["/usr/local/bin/factory-server"]
