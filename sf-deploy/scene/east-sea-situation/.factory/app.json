{
  "schemaVersion": 1,
  "slug": "east-sea-situation",
  "name": "东海目标态势演示",
  "type": "map-dashboard",
  "source": "preset",
  "description": "基于东海卫星地图展示目标列表、轨迹、警戒区、事件时间线和融合态势面板。",
  "entry": "static-vite",
  "path": "scene/east-sea-situation",
  "tags": ["map", "situation", "east-sea"],
  "build": {
    "command": "npm run build",
    "outputDir": "dist"
  },
  "runtime": {
    "devCommand": "npm run dev",
    "defaultPort": 5173
  },
  "docker": {
    "enabled": true,
    "dockerfile": "Dockerfile",
    "context": ".",
    "runtimePort": 80
  }
}
